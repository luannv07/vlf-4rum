@*
    _Modal.cshtml — Modal dialog
    ──────────────────────────────────────────
    Props (ViewData):
      Id*      string  — unique id, dùng cho Modal.open('id')
      Title    string  — tiêu đề header
      Size     string  — sm(400px)|md(520px)|lg(720px)  (default: md)
      Body     string  — HTML nội dung (dùng Html.Raw)
      Footer   string  — HTML footer buttons (dùng Html.Raw)
    ──────────────────────────────────────────
    JS: Modal.open('id') / Modal.close('id')
*@
@{
    var id     = ViewData["Id"]?.ToString() ?? "modal";
    var title  = ViewData["Title"]?.ToString() ?? "";
    var size   = ViewData["Size"]?.ToString() ?? "md";
    var body   = ViewData["Body"]?.ToString() ?? "";
    var footer = ViewData["Footer"]?.ToString() ?? "";

    var maxWidthMap = new Dictionary<string, string>
    {
        ["sm"] = "400px",
        ["md"] = "520px",
        ["lg"] = "720px",
    };
    var maxWidth = maxWidthMap.TryGetValue(size, out var w) ? w : "520px";
}

<div id="@id"
     class="modal-overlay"
     onclick="if(event.target===this)Modal.close('@id')">

    <div class="modal" style="max-width:@maxWidth;">

        <div class="modal-header">
            <span class="modal-title">@title</span>
            <button class="modal-close"
                    type="button"
                    onclick="Modal.close('@id')"
                    aria-label="Đóng">✕</button>
        </div>

        @if (!string.IsNullOrEmpty(body))
        {
            <div class="modal-body">
                @Html.Raw(body)
            </div>
        }

        @if (!string.IsNullOrEmpty(footer))
        {
            <div class="modal-footer">
                @Html.Raw(footer)
            </div>
        }

    </div>
</div>
