@*
    _Avatar.cshtml — User avatar
    ──────────────────────────────────────────
    Props (ViewData):
      Username*  string  — dùng cho alt + dicebear seed
      Src        string  — URL ảnh (fallback dicebear nếu null)
      Size       string  — xs|sm|md|lg|xl  (default: md)
      Online     bool    — hiện dot xanh online
      Ring       bool    — border accent xanh
      Href       string  — bọc trong <a> nếu có
*@
@{
    var username = ViewData["Username"]?.ToString() ?? "user";
    var src      = ViewData["Src"]?.ToString();
    var size     = ViewData["Size"]?.ToString() ?? "md";
    var online   = ViewData["Online"] is true;
    var ring     = ViewData["Ring"]   is true;
    var href     = ViewData["Href"]?.ToString();

    if (string.IsNullOrEmpty(src))
    {
        src = $"https://api.dicebear.com/7.x/avataaars/svg?seed={Uri.EscapeDataString(username)}";
    }

    var borderClass = ring ? "avatar-ring" : "avatar-bordered";
    var imgClass    = $"avatar avatar-{size} {borderClass}";
    var needWrapper = online || !string.IsNullOrEmpty(href);
}

@if (needWrapper)
{
    if (!string.IsNullOrEmpty(href))
    {
        <a href="@href" class="avatar-wrapper" style="text-decoration:none;">
            <img src="@src" class="@imgClass" alt="@username" />
            @if (online)
            {
                <span class="online-dot"></span>
            }
        </a>
    }
    else
    {
        <div class="avatar-wrapper">
            <img src="@src" class="@imgClass" alt="@username" />
            <span class="online-dot"></span>
        </div>
    }
}
else
{
    <img src="@src" class="@imgClass" alt="@username" />
}
