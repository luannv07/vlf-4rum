@*
    _Textarea.cshtml — Multiline text input
    ──────────────────────────────────────────
    Props (ViewData):
      Name*       string
      Label       string
      Placeholder string
      Value       string
      Hint        string
      Error       string
      Rows        int    (default: 4)
      Required    bool
      MaxLength   int
*@
@{
    var name        = ViewData["Name"]?.ToString() ?? "";
    var label       = ViewData["Label"]?.ToString();
    var placeholder = ViewData["Placeholder"]?.ToString() ?? "";
    var value       = ViewData["Value"]?.ToString() ?? "";
    var hint        = ViewData["Hint"]?.ToString();
    var error       = ViewData["Error"]?.ToString();
    var required    = ViewData["Required"] is true;
    var rows        = ViewData["Rows"] != null ? Convert.ToInt32(ViewData["Rows"]) : 4;
    var maxLength   = ViewData["MaxLength"] != null
                        ? Convert.ToInt32(ViewData["MaxLength"])
                        : (int?)null;

    var hasError   = !string.IsNullOrEmpty(error);
    var inputClass = hasError ? "textarea input-error" : "textarea";
}

<div class="form-group">

    @if (!string.IsNullOrEmpty(label))
    {
        <label class="form-label" for="@name">
            @label
            @if (required)
            {
                <span style="color:var(--accent-red);margin-left:2px;">*</span>
            }
        </label>
    }

    <textarea class="@inputClass"
              id="@name"
              name="@name"
              rows="@rows"
              placeholder="@placeholder"
              maxlength="@maxLength"
              required="@(required ? "required" : null)">@value</textarea>

    @if (maxLength.HasValue)
    {
        <span class="form-hint" style="text-align:right;">0 / @maxLength</span>
    }

    @if (hasError)
    {
        <span class="form-error">⚠ @error</span>
    }
    else if (!string.IsNullOrEmpty(hint))
    {
        <span class="form-hint">@hint</span>
    }

</div>
