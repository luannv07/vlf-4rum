@*
    _Input.cshtml — Text input field
    ──────────────────────────────────────────
    Props (ViewData):
      Name*         string  — input name & id
      Label         string  — label text
      Type          string  — text|email|password|number|url  (default: text)
      Placeholder   string
      Value         string
      Hint          string  — helper text bên dưới
      Error         string  — validation error
      Required      bool
      Readonly      bool
      Disabled      bool
      MaxLength     int
    ──────────────────────────────────────────
    Dùng:
      @await Html.PartialAsync("Components/_Input", null, new ViewDataDictionary(ViewData) {
          { "Name", "Email" }, { "Label", "Email" },
          { "Type", "email" }, { "Required", true }
      })
*@
@{
    var name        = ViewData["Name"]?.ToString() ?? "";
    var label       = ViewData["Label"]?.ToString();
    var type        = ViewData["Type"]?.ToString() ?? "text";
    var placeholder = ViewData["Placeholder"]?.ToString() ?? "";
    var value       = ViewData["Value"]?.ToString() ?? "";
    var hint        = ViewData["Hint"]?.ToString();
    var error       = ViewData["Error"]?.ToString();
    var required    = ViewData["Required"] is true;
    var isReadonly  = ViewData["Readonly"] is true;
    var disabled    = ViewData["Disabled"] is true;
    var maxLength   = ViewData["MaxLength"] != null
                        ? Convert.ToInt32(ViewData["MaxLength"])
                        : (int?)null;

    var hasError   = !string.IsNullOrEmpty(error);
    var inputClass = hasError ? "input input-error" : "input";
}

<div class="form-group">

    @if (!string.IsNullOrEmpty(label))
    {
        <label class="form-label" for="@name">
            @label
            @if (required)
            {
                <span style="color:var(--accent-red);margin-left:2px;">*</span>
            }
        </label>
    }

    <input class="@inputClass"
           type="@type"
           id="@name"
           name="@name"
           placeholder="@placeholder"
           value="@value"
           maxlength="@maxLength"
           required="@(required ? "required" : null)"
           readonly="@(isReadonly ? "readonly" : null)"
           disabled="@(disabled ? "disabled" : null)" />

    @if (hasError)
    {
        <span class="form-error">⚠ @error</span>
    }
    else if (!string.IsNullOrEmpty(hint))
    {
        <span class="form-hint">@hint</span>
    }

</div>
