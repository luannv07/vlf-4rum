@*
    _Pagination.cshtml — Page navigation
    ──────────────────────────────────────────
    Props (ViewData):
      CurrentPage*  int
      TotalPages*   int
      UrlPattern*   string  — URL với {0} là số trang
                              vd: "/Post?page={0}" hoặc "/Post/Index?page={0}"
*@
@{
    var currentPage = ViewData["CurrentPage"] != null ? Convert.ToInt32(ViewData["CurrentPage"]) : 1;
    var totalPages  = ViewData["TotalPages"]  != null ? Convert.ToInt32(ViewData["TotalPages"])  : 1;
    var urlPattern  = ViewData["UrlPattern"]?.ToString() ?? "?page={0}";

    var start = Math.Max(1, currentPage - 2);
    var end   = Math.Min(totalPages, currentPage + 2);
}

@if (totalPages > 1)
{
    <nav class="pagination" aria-label="Phân trang">

        @* Prev *@
        @if (currentPage > 1)
        {
            <a href="@string.Format(urlPattern, currentPage - 1)" class="page-btn">← Trước</a>
        }
        else
        {
            <span class="page-btn disabled">← Trước</span>
        }

        @* Trang đầu *@
        @if (start > 1)
        {
            <a href="@string.Format(urlPattern, 1)" class="page-btn">1</a>
            if (start > 2)
            {
                <span class="page-btn" style="border:none;background:none;cursor:default;">…</span>
            }
        }

        @* Các trang giữa *@
        @for (int p = start; p <= end; p++)
        {
            if (p == currentPage)
            {
                <span class="page-btn active">@p</span>
            }
            else
            {
                <a href="@string.Format(urlPattern, p)" class="page-btn">@p</a>
            }
        }

        @* Trang cuối *@
        @if (end < totalPages)
        {
            if (end < totalPages - 1)
            {
                <span class="page-btn" style="border:none;background:none;cursor:default;">…</span>
            }
            <a href="@string.Format(urlPattern, totalPages)" class="page-btn">@totalPages</a>
        }

        @* Next *@
        @if (currentPage < totalPages)
        {
            <a href="@string.Format(urlPattern, currentPage + 1)" class="page-btn">Sau →</a>
        }
        else
        {
            <span class="page-btn disabled">Sau →</span>
        }

    </nav>
}
