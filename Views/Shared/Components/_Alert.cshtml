@*
    _Alert.cshtml — Inline alert / notification
    ──────────────────────────────────────────
    Props (ViewData):
      Message*    string  — nội dung
      Type        string  — info|success|warning|danger  (default: info)
      Icon        string  — override icon mặc định
      Dismissible bool    — hiện nút đóng
*@
@{
    var message     = ViewData["Message"]?.ToString() ?? "";
    var type        = ViewData["Type"]?.ToString() ?? "info";
    var dismissible = ViewData["Dismissible"] is true;

    var iconMap = new Dictionary<string, string>
    {
        ["info"]    = "ℹ️",
        ["success"] = "✅",
        ["warning"] = "⚠️",
        ["danger"]  = "❌",
    };

    var icon = ViewData["Icon"]?.ToString()
               ?? (iconMap.TryGetValue(type, out var defaultIcon) ? defaultIcon : "ℹ️");
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-@type" role="alert">
        <span>@icon</span>
        <span style="flex:1;">@message</span>
        @if (dismissible)
        {
            <button type="button"
                    onclick="this.closest('.alert').remove()"
                    style="background:none;border:none;cursor:pointer;font-size:16px;color:inherit;opacity:.7;padding:0;line-height:1;">
                ✕
            </button>
        }
    </div>
}
