@*
    _Badge.cshtml — Badge / Tag / Status chip
    ──────────────────────────────────────────
    Props (ViewData):
      Text*    string  — nội dung
      Variant  string  — default|blue|green|red|yellow|purple|teal
                         status-active|status-banned|status-mod|status-pending
      Icon     string  — emoji trước text
*@
@{
    var text    = ViewData["Text"]?.ToString() ?? "";
    var variant = ViewData["Variant"]?.ToString() ?? "default";
    var icon    = ViewData["Icon"]?.ToString();

    var isStatus = variant.StartsWith("status-");
    string cssClass;

    if (isStatus)
        cssClass = $"status {variant}";
    else if (variant == "default")
        cssClass = "badge";
    else
        cssClass = $"tag tag-{variant}";
}

@if (!string.IsNullOrEmpty(text))
{
    <span class="@cssClass">
        @if (!string.IsNullOrEmpty(icon))
        {
            <span>@icon</span>
        }
        @text
    </span>
}
