@*
    _EmptyState.cshtml — Empty / no data placeholder
    ──────────────────────────────────────────
    Props (ViewData):
      Icon     string  — emoji  (default: 📭)
      Title    string  — tiêu đề  (default: "Không có dữ liệu")
      Desc     string  — mô tả phụ
      Action   string  — HTML button/link hành động
*@
@{
    var icon   = ViewData["Icon"]?.ToString()  ?? "📭";
    var title  = ViewData["Title"]?.ToString() ?? "Không có dữ liệu";
    var desc   = ViewData["Desc"]?.ToString();
    var action = ViewData["Action"]?.ToString();
}

<div class="empty-state">
    <div class="empty-state-icon">@icon</div>
    <h3 class="empty-state-title">@title</h3>
    @if (!string.IsNullOrEmpty(desc))
    {
        <p class="empty-state-desc">@desc</p>
    }
    @if (!string.IsNullOrEmpty(action))
    {
        @Html.Raw(action)
    }
</div>
