@using vlf_4rum.TagHelpers
@*
    _Button.cshtml
    ════════════════════════════════════════
    Props:
      Text      string   default: "Button"
      Icon      string   default: null
      IconRight string   default: null
      IconOnly  bool     default: false
      Variant   string   primary|secondary|ghost|outline|danger|success|warning|link   default: primary
      Size      string   xs|sm|md|lg|xl   default: md
      Block     bool     default: false
      Loading   bool     default: false
      Disabled  bool     default: false
      Type      string   button|submit|reset   default: button
      Href      string   default: null
      Target    string   default: null
      OnClick   string   default: null
*@
@{
    var text = ViewData["Text"]?.ToString() ?? "Button";
    var icon = ViewData["Icon"]?.ToString();
    var iconRight = ViewData["IconRight"]?.ToString();
    var iconOnly = ViewData["IconOnly"] is true;
    var variant = ViewData["Variant"]?.ToString() ?? "primary";
    var size = ViewData["Size"]?.ToString() ?? "md";
    var block = ViewData["Block"] is true;
    var loading = ViewData["Loading"] is true;
    var disabled = ViewData["Disabled"] is true || loading;
    var type = ViewData["Type"]?.ToString() ?? "button";
    var href = ViewData["Href"]?.ToString();
    var target = ViewData["Target"]?.ToString();
    var onClick = ViewData["OnClick"]?.ToString();
    var addClass = ViewData["AddClass"]?.ToString();

    var finalClass = string.Join(" ",
        new[] {
            block ? "w-full justify-center" : "inline-flex",
            "items-center font-medium leading-none whitespace-nowrap select-none",
            "transition-all duration-150 ease-in-out",
            "focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--border-focus)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-base)]",
            "active:scale-[0.97] rounded-[var(--radius-md)]",
            Ui.Size(size, iconOnly),
            Ui.Variant(variant),
            disabled ? "opacity-50 cursor-not-allowed pointer-events-none" : "cursor-pointer",
            addClass
        }.Where(c => !string.IsNullOrWhiteSpace(c))
    );
}

@if (!string.IsNullOrEmpty(href))
{
    <a href="@(disabled ? null : href)" class="@finalClass" aria-label="@text" target="@target"
           rel="@(target == "_blank" ? "noopener noreferrer" : null)" aria-disabled="@(disabled ? "true" : null)"
           onclick="@(onClick != null ? Html.Raw(onClick) : null)">
        @if (loading)
        {
            <span class="@Ui.Spinner(size) border-current border-t-transparent rounded-full animate-spin"
                  aria-hidden="true"></span>
        }
        else if (!string.IsNullOrEmpty(icon))
        {
            <span class="leading-none" aria-hidden="true">@icon</span>
        }
        @if (!iconOnly)
        {
            <span>@text</span>
        }
        @if (!loading && !string.IsNullOrEmpty(iconRight))
        {
            <span class="leading-none" aria-hidden="true">@iconRight</span>
        }
    </a>
}
else
{
    <button type="@type" class="@finalClass" aria-label="@text" aria-busy="@(loading ? "true" : null)"
            disabled="@(disabled ? "disabled" : null)" onclick="@(onClick != null ? Html.Raw(onClick) : null)">
        @if (loading)
        {
            <span class="@Ui.Spinner(size) border-current border-t-transparent rounded-full animate-spin"
                  aria-hidden="true"></span>
        }
        else if (!string.IsNullOrEmpty(icon))
        {
            <span class="leading-none" aria-hidden="true">@icon</span>
        }
        @if (!iconOnly)
        {
            <span>@text</span>
        }
        @if (!loading && !string.IsNullOrEmpty(iconRight))
        {
            <span class="leading-none" aria-hidden="true">@iconRight</span>
        }
    </button>
}